# --- Waitlist (server-only; never prefix with NEXT_PUBLIC) ---
# Same Supabase project as the main app. Required for POST /api/waitlist inserts.
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use the Project URL only (Settings → Data API / API). Do not append /rest/v1 — the route adds that.
# Never expose the service role key to the browser or client bundles.
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: override where /deck embeds the live webapp demo bootstrap.
# Default in code is https://valet-ventures.vercel.app — iframe loads `/deck-demo`, which signs in
# the Edge-configured demo user, then opens `/garage?deckEmbed=1`.
# NEXT_PUBLIC_WEBAPP_URL=

# Optional: iframe URL becomes /deck-demo?deckDemoDebug=1 — step log inside the phone frame + console [deck-demo].
# NEXT_PUBLIC_DECK_IFRAME_DEBUG=true

# Optional: `/presenter` gate — extra passwords (comma-separated), in addition to built-ins `123` and `Pitch2026`.
# NEXT_PUBLIC_PRESENTER_ACCESS_PASSWORD=
